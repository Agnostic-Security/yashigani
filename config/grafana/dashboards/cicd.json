{
  "uid": "yashigani-cicd",
  "title": "Yashigani \u2014 SDLC AI Supply Chain Security",
  "tags": [
    "yashigani",
    "supply-chain",
    "security",
    "sdlc"
  ],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "5m",
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "panels": [
    {
      "id": 11,
      "type": "text",
      "title": "",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 3
      },
      "options": {
        "mode": "markdown",
        "content": "Supply chain security posture for Yashigani deployments \u2014 CVE counts by image, test coverage, security scan failures, image signature and SBOM integrity. Metrics are pushed by CI Trivy/Cosign jobs via Pushgateway."
      }
    },
    {
      "id": 1,
      "type": "stat",
      "title": "HIGH/CRITICAL CVEs \u2014 Gateway",
      "gridPos": {
        "x": 0,
        "y": 3,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "yashigani_trivy_high_cve_count{image=\"gateway\"}",
          "legendFormat": "CVEs"
        }
      ],
      "options": {
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          },
          "mappings": []
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "HIGH/CRITICAL CVEs \u2014 Backoffice",
      "gridPos": {
        "x": 6,
        "y": 3,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "yashigani_trivy_high_cve_count{image=\"backoffice\"}",
          "legendFormat": "CVEs"
        }
      ],
      "options": {
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
