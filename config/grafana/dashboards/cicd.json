          },
          "mappings": []
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Test Coverage %",
      "gridPos": {
        "x": 12,
        "y": 3,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "yashigani_test_coverage_percent",
          "legendFormat": "Coverage"
        }
      ],
      "options": {
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 70
              },
              {
                "color": "green",
                "value": 80
              }
            ]
          },
          "mappings": []
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Security Scan Failures (7d)",
      "gridPos": {
        "x": 18,
        "y": 3,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "increase(yashigani_security_scan_failures_total[7d])",
          "legendFormat": "Failures"
        }
      ],
      "options": {
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
