# Yashigani — Caddy TLS edge (CA-signed certificate mode)
# Last updated: 2026-05-18T00:00:00+00:00 (v2.23.4: add handle /openapi.json + /docs blocks — close Iris Seam 15 — openapi+docs edge routing)
# Use this for enterprise / on-prem deployments with an internal CA.
#
# Before starting:
#   1. Place your certificate chain at ./tls/server.crt
#   2. Place your private key at ./tls/server.key
#   3. Set YASHIGANI_TLS_DOMAIN in .env
#
# Caddy will NOT attempt ACME in this mode.
# Certificate renewal is the operator's responsibility (or use certbot separately).
#
# ── DDoS / Connection Protection ────────────────────────────────────────────
# See Caddyfile.acme header comment for full explanation.
# Full WAF requires a custom Caddy build — see docker/caddy/Caddyfile.waf.

{
    # ── Public-edge SNI defaulting (TLS fix, 2026-06-11) ───────────────────
    # Identical mechanism to Caddyfile.selfsigned: client_auth (verify_if_given)
    # on the public site compiles an SNI-matched TLS policy plus an empty catch-
    # all, so a no-SNI / mismatched-SNI / direct-IP handshake aborts with `tlsv1
    # alert internal error` / RECORD_LAYER_FAILURE. default_sni folds the no-SNI
    # case into the cert-bearing policy; fallback_sni serves the <domain> cert for
    # non-matching SNIs. Safe: single path-routed edge, no host vhosting.
    # (Selfsigned mode is the runtime-verified path for this fix; BYO-CA shares
    # the identical Caddy connection-policy semantics.)
    default_sni {$YASHIGANI_TLS_DOMAIN}
    fallback_sni {$YASHIGANI_TLS_DOMAIN}

    # ── Admin API — unix socket only (MUST-4 / v2.24.1 hardening) ───────────
    # TCP :2019 removed. Filesystem permissions are the auth gate.
    # In-container tooling (healthcheck, reload) uses the socket directly.
    # No other service on any network can reach this surface.
    admin unix//run/caddy/admin.sock

    # ── Connection timeouts (DoS/slow-loris mitigation) ─────────────────────
    servers {
        timeouts {
            read_body   10s
            read_header 5s
            write       120s  # raised 30→120s: accommodates local LLM generations; warm models keep normal responses ~8s
            idle        120s
        }
        # ── SNI-host enforcement (public-edge TLS fix, 2026-06-11) ──────────
        # The public site configures client_auth (verify_if_given) to extract a
        # SPIFFE URI from an optionally-presented client cert on /agents/* + /v1/*.
        # Caddy AUTO-ENABLES strict SNI-host enforcement on any server that has
        # client_auth configured, which REJECTS the TLS handshake (`tlsv1 alert
        # internal error` / RECORD_LAYER_FAILURE) for every connection whose SNI
        # != the site host — i.e. clients reaching the edge by IP or with NO SNI
        # fail. `insecure_off` disables the SNI-host *match* gate: safe here
        # because this edge serves a single path-routed site (no host vhosting,
        # so no host-confusion class). verify_if_given SPIFFE extraction and the
        # mesh listeners :8444/:8445 are unaffected. See Caddyfile.selfsigned.
        strict_sni_host insecure_off
    }
}

# ─── Internal mTLS snippet (imported by every upstream block that targets a
#     service terminating mTLS: gateway:8080, backoffice:8443). ─────────────
(internal-mtls) {
    transport http {
        tls
        tls_trust_pool file /run/secrets/ca_intermediate.crt
        tls_client_auth /run/secrets/caddy_client.crt /run/secrets/caddy_client.key
        # Force HTTP/1.1: Caddy v2.11.x drops headers set via
        # reverse_proxy.headers.request.set on HTTP/2 upstream connections.
        # Confirmed R4 macOS Podman gate 2026-04-30.
        versions 1.1
    }
}

# ─────────────────────────────────────────────────────────────────────────────
# Layer B — Caddy HMAC shared-secret marker (EX-231-10 Layer B).
# Last updated: 2026-04-30T23:05:00+01:00
#
# DESIGN DECISION: static-shared-secret variant. See Caddyfile.selfsigned for
# full rationale. caddy:2-alpine has no inline HMAC computation capability.
#
# Caddy reads CADDY_INTERNAL_HMAC from env (sourced from the secret file) and
# injects it as X-Caddy-Verified-Secret on every upstream proxy call to
# gateway:8080 and backoffice:8443. the gateway/backoffice middleware does
# hmac.compare_digest(header_value, stored_secret) → 401 if absent or mismatched.
#
# IMPORTANT: {$CADDY_INTERNAL_HMAC} is parse-time env substitution. Do NOT use
# {env.CADDY_INTERNAL_HMAC} — that is a request-time placeholder not resolved
# in header_up directives (Round 1 failure root cause, 2026-04-29).
#
# STRIP INBOUND: `set` alone (without a preceding `-X-Caddy-Verified-Secret`
# delete) overwrites any inbound attacker-supplied value. The delete+set
# approach is NOT used because Caddy v2.11.x applies set-before-delete in the
# headers.request JSON object, causing the header to go missing. Confirmed R4
# macOS Podman gate 2026-04-30. See Caddyfile.selfsigned for full rationale.
# ─────────────────────────────────────────────────────────────────────────────
# ─────────────────────────────────────────────────────────────────────────────
# Strip orchestration-context headers at the public edge (LAURA/IRIS drift).
# X-Yashigani-Orchestration-* carry the agent-orchestration identity context
# (depth, principal, root-request-id) the gateway uses for model-RBAC. A real
# external user proved they can FORGE X-Yashigani-Orchestration-Depth at the
# public edge to bypass model-RBAC. These headers are LEGITIMATE only on the
# internal mesh self-call path (gateway:8081), exactly like X-OpenWebUI-User-*.
# Imported into EVERY public handle that reaches the gateway (direct or via the
# OWUI catch-all). Single-source snippet = no per-handle drift across renders.
# Pairs with Tom's gateway-side identity-gate (the two halves ship together).
# `request_header -X` (delete) runs unconditionally; no inbound value survives
# to the gateway, so it can only ever see an internally-set value.
# ─────────────────────────────────────────────────────────────────────────────
(strip-orchestration-headers) {
    request_header -X-Yashigani-Orchestration-Depth
    request_header -X-Yashigani-Orchestration-Principal
    request_header -X-Yashigani-Orchestration-Root-Request-Id
    # Defence-in-depth catch for any future X-Yashigani-Orchestration-* header.
    request_header -X-Yashigani-Orchestration-*
}

(inject-caddy-verified) {
    # Inject the per-install shared secret via parse-time env substitution.
    # {$CADDY_INTERNAL_HMAC} resolves at Caddy startup to the literal secret
    # value read from the CADDY_INTERNAL_HMAC environment variable (populated
    # from /run/secrets/caddy_internal_hmac by install.sh).
    header_up X-Caddy-Verified-Secret {$CADDY_INTERNAL_HMAC}
}

{$YASHIGANI_TLS_DOMAIN} {
    # ── TLS policy — CA-signed certificate ──────────────────────────────────
    tls /etc/caddy/tls/server.crt /etc/caddy/tls/server.key {
        # TLS 1.3 minimum + GCM-only ciphers. maintainer directive 2026-04-30.
        # Closes QA finding (was negotiating TLS 1.2 + ChaCha20-Poly1305).
        protocols tls1.3
        ciphers TLS_AES_256_GCM_SHA384 TLS_AES_128_GCM_SHA256
        # Hybrid post-quantum key exchange (HNDL protection)
        curves x25519mlkem768 x25519 secp384r1 secp256r1
        # V10.3.5 sender-constrained tokens: verify client cert if presented.
        # `verify_if_given` accepts non-mTLS browser connections AND extracts
        # SPIFFE URI from a presented client cert when one is given. Per-path
        # SPIFFE forwarding stays in handle blocks. Caddy v2 requires
        # client_auth at the server-block tls directive, not inside handle —
        # Platform gate #58c #3br evidence (2026-04-28).
        client_auth {
            mode verify_if_given
            trust_pool file /run/secrets/ca_intermediate.crt
        }
    }

    # ── Security headers ────────────────────────────────────────────────────
    # Browser security features expected by Yashigani:
    # - HSTS: Strict-Transport-Security enforced (preload, 2-year max-age)
    # - CSP: Content-Security-Policy with strict directives
    # - X-Content-Type-Options: nosniff (prevents MIME sniffing)
    # - X-Frame-Options: DENY (prevents clickjacking)
    # - COOP: Cross-Origin-Opener-Policy: same-origin
    # - Referrer-Policy: no-referrer
    # Fallback: if a browser lacks these features, Yashigani's
    # server-side controls (OPA, session validation, CSRF via SameSite)
    # provide equivalent protection without client-side enforcement.
    header {
        Strict-Transport-Security  "max-age=63072000; includeSubDomains; preload"
        X-Content-Type-Options     "nosniff"
        X-Frame-Options            "DENY"
        Referrer-Policy            "no-referrer"
        # CSP is set per-path below (NOT here) — a global SET would shadow the
        # per-path override and break the proxied sub-apps + Open WebUI.
        Cross-Origin-Opener-Policy "same-origin"
        # Product / fingerprint hygiene (QA Wave 2 observations 5 + 6).
        -Server
        -Via
        -Alt-Svc
    }

    # CSP, set per-path so exactly one policy applies per request.
    #
    # STRICT (script-src 'self', style-src 'self', no inline) applies to the
    # Yashigani-native admin plane ONLY — the backoffice SPA (/admin/*), auth
    # (/auth/*, /login), and the other first-party backoffice routes. These were
    # deliberately made strict-CSP-compliant (inline styles moved to CSS classes,
    # f7a3228); do NOT weaken them.
    #
    # LENIENT (unsafe-eval + unsafe-inline) applies to everything else:
    #  - the proxied observability sub-apps (Grafana, Wazuh/OSD, Prometheus),
    #    which ship nonce-less inline bootstrap scripts + eval()/inline styles;
    #  - the Open WebUI end-user chat surface served at the root catch-all
    #    (--with-openwebui), whose SvelteKit build emits inline hydration scripts —
    #    strict CSP blocks them and the page renders blank (YSG-2253 blocker).
    #
    # The boundary is a single path set used in both matchers so exactly one
    # policy applies per request.
    @strict_ui {
        path /admin/* /auth/* /me/* /dashboard/* /scim/* /api/v1/admin/* /static/* /login /login/* /docs /redoc /openapi.json
        not path /admin/grafana/* /admin/wazuh/* /admin/prometheus/*
    }
    @lenient_ui not path /admin/* /auth/* /me/* /dashboard/* /scim/* /api/v1/admin/* /static/* /login /login/* /docs /redoc /openapi.json
    @lenient_subapp path /admin/grafana/* /admin/wazuh/* /admin/prometheus/*
    # N2 (2.25.5): ReDoc requires worker-src blob: child-src blob: because it
    # spawns a Web Worker via blob: URL for syntax highlighting.  Scoped only
    # to the two ReDoc routes; all other strict_ui paths keep the default CSP.
    # 'unsafe-inline' on style-src is also required: Redoc injects inline CSS
    # via its web component Shadow DOM at render time.
    @redoc_ui path /admin/api-redoc /redoc
    header @strict_ui Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' data:; font-src 'self'; connect-src 'self'; object-src 'none'; base-uri 'none'; frame-ancestors 'none'; form-action 'self'; report-uri /admin/csp-report; report-to default"
    header @lenient_ui Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-eval' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self' ws: wss:; worker-src 'self' blob:; frame-ancestors 'none'; object-src 'none'; base-uri 'none'"
    header @lenient_subapp Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-eval' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self' ws: wss:; worker-src 'self' blob:; frame-ancestors 'none'; object-src 'none'; base-uri 'none'"
    header @redoc_ui Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self'; worker-src blob:; child-src blob:; object-src 'none'; base-uri 'none'; frame-ancestors 'none'; form-action 'self'; report-uri /admin/csp-report; report-to default"

    # ── Request body size limit (OWASP ASVS 4.1.7) ──────────────────────────
    request_body {
        max_size 10MB
    }

    # ── RFC 9116 security.txt — vulnerability disclosure ──────────────────
    handle /.well-known/security.txt {
        header Content-Type "text/plain; charset=utf-8"
        respond `Contact: mailto:security@agnosticsec.com
Contact: https://github.com/agnostic-security/yashigani/security/advisories/new
Expires: 2027-04-22T00:00:00Z
Preferred-Languages: en
Policy: https://agnosticsec.com/security
Hiring: https://agnosticsec.com/careers
` 200
    }

    # ── Gateway health check — /healthz ──────────────────────────────────
    handle /healthz {
        import strip-orchestration-headers
        reverse_proxy https://gateway:8080 {
        import internal-mtls
        import inject-caddy-verified
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }

    # ── Agent routing — /agents/* ──────────────────────────────────────────
    # Site-level `tls { client_auth { ... } }` does the verify;
    # this handle just forwards SPIFFE URI from the validated peer cert.
    handle /agents/* {
        request_header -X-SPIFFE-ID
        request_header X-SPIFFE-ID {http.request.tls.client.san.uris.0}
        import strip-orchestration-headers
        reverse_proxy https://gateway:8080 {
        import internal-mtls
        import inject-caddy-verified
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }

    # ── Gateway API — /v1/* (OpenAI-compatible) ─────────────────────────
    # Same as /agents/* — site-level client_auth, per-path SPIFFE forwarding.
    handle /v1/* {
        request_header -X-SPIFFE-ID
        request_header X-SPIFFE-ID {http.request.tls.client.san.uris.0}
        # Track C (F-B) anti-spoof: strip any client-supplied forwarded-user
        # identity headers on the public /v1 path so an external caller cannot
        # impersonate an OWUI user. ONLY OWUI (internal, via gateway:8081) may
        # set these; the gateway honours them solely under the internal bearer.
        request_header -X-OpenWebUI-User-Email
        request_header -X-OpenWebUI-User-Id
        request_header -X-OpenWebUI-User-Name
        request_header -X-OpenWebUI-User-Role
        request_header -X-Forwarded-User
        import strip-orchestration-headers
        reverse_proxy https://gateway:8080 {
        import internal-mtls
        import inject-caddy-verified
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }

    # ── MCP JWKS — /.well-known/yashigani-mcp-jwks.json (PUBLIC, no auth) ──
    # Public key retrieval endpoint — no forward_auth gate required.
    # ASVS V2.6.3; must appear before catch-all handle {} block.
    # Last updated: 2026-05-30 (P3 broker E2E gate — J8-JWKS fix)
    handle /.well-known/yashigani-mcp-jwks.json {
        import strip-orchestration-headers
        reverse_proxy https://gateway:8080 {
        import internal-mtls
        import inject-caddy-verified
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }

    handle /mcp/* {
        import strip-orchestration-headers
        reverse_proxy https://gateway:8080 {
        import internal-mtls
        import inject-caddy-verified
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }

    # ── Gateway OpenAPI surface — /openapi.json + /docs + /redoc ────────
    # Iris Seam 15 (PR #145): gateway:8080 serves GET /openapi.json and
    # GET /docs (Swagger UI) via gateway identity-resolution middleware.
    # N2 (2.25.5): /redoc added — ReDoc navigable API map, same auth gate.
    # Without explicit handles these requests fell through to the Open WebUI
    # catch-all and were functionally unreachable.
    handle /openapi.json {
        import strip-orchestration-headers
        reverse_proxy https://gateway:8080 {
        import internal-mtls
        import inject-caddy-verified
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }

    handle /docs {
        import strip-orchestration-headers
        reverse_proxy https://gateway:8080 {
        import internal-mtls
        import inject-caddy-verified
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }

    handle /redoc {
        import strip-orchestration-headers
        reverse_proxy https://gateway:8080 {
        import internal-mtls
        import inject-caddy-verified
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }

    # ── Backoffice routes: /admin/*, /auth/*, /dashboard/*, /scim/* ───────
    # ISSUE-019 (2026-05-19): inject Caddy's own SPIFFE identity on the
    # Caddy→backoffice leg so require_spiffe_id("/admin/agents") can verify the
    # caller.  See Caddyfile.selfsigned for full rationale.
    handle /admin/* {
        request_header -X-SPIFFE-ID
        request_header X-SPIFFE-ID "spiffe://yashigani.internal/caddy"
        reverse_proxy https://backoffice:8443 {
        import internal-mtls
        import inject-caddy-verified
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }

    handle /auth/* {
        reverse_proxy https://backoffice:8443 {
        import internal-mtls
        import inject-caddy-verified
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }

    handle /me/* {
        reverse_proxy https://backoffice:8443 {
        import internal-mtls
        import inject-caddy-verified
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }

    handle /dashboard/* {
        reverse_proxy https://backoffice:8443 {
        import internal-mtls
        import inject-caddy-verified
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }

    handle /scim/* {
        reverse_proxy https://backoffice:8443 {
        import internal-mtls
        import inject-caddy-verified
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }

    # ── Admin API — /api/v1/admin/* (PKI, HIBP, secrets, WebAuthn) ────────
    # Must be explicit before the catch-all (which routes to open-webui).
    # Regression test: SWEEP-16 in test_v2233_ava_sweep.py
    # ASVS V9.1, API5 BFLA — fix for v2.23.3 release blocker.
    # Last updated: 2026-05-09T00:00:00+00:00 (v2.23.3)
    handle /api/v1/admin/* {
        # SIDE-001 (Iris drift gate v2.25.0 P2 wave 3, DRIFT-B4-SPIFFE-COMPOSE-API-ADMIN):
        # strip any inbound X-SPIFFE-ID before reverse-proxy so a client cannot
        # spoof the identity header to backoffice on this path. Mirrors /admin/*
        # treatment. Helm chart already does this in v2.25.0 P2 B4 closure;
        # compose was missing SIDE-001 on this block (added v2.23.3, predates
        # SIDE-001 hardening).
        request_header -X-SPIFFE-ID
        request_header X-SPIFFE-ID "spiffe://yashigani.internal/caddy"
        reverse_proxy https://backoffice:8443 {
        import internal-mtls
        import inject-caddy-verified
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }

    # ── Grafana — admin-authenticated access via /admin/grafana/* ──────────
    # retro #83: Grafana now serves HTTPS on port 3443 with mTLS (Pattern B).
    # Caddy presents caddy_client.crt to Grafana; Grafana verifies via
    # ca_intermediate.crt. The forward_auth check still applies (admin only).
    handle_path /admin/grafana/* {
        forward_auth https://backoffice:8443 {
        import internal-mtls
        import inject-caddy-verified
            uri /auth/verify
            @unauthorized status 401
            handle_response @unauthorized {
                redir * /admin/login?next=/admin/grafana/ 302
            }
        }
        reverse_proxy https://grafana:3443 {
            import internal-mtls
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }

    # ── Wazuh Dashboard — admin-authenticated access via /admin/wazuh/* ────
    handle_path /admin/wazuh/* {
        forward_auth https://backoffice:8443 {
        import internal-mtls
        import inject-caddy-verified
            uri /auth/verify
            @unauthorized status 401
            handle_response @unauthorized {
                redir * /admin/login 302
            }
        }
        reverse_proxy wazuh-dashboard:5601 {
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }

    # ── Prometheus — admin-authenticated access via /admin/prometheus/* ───
    # retro #83: Prometheus now serves HTTPS on port 9090 (Pattern B mTLS).
    handle_path /admin/prometheus/* {
        forward_auth https://backoffice:8443 {
        import internal-mtls
        import inject-caddy-verified
            uri /auth/verify
            @unauthorized status 401
            handle_response @unauthorized {
                redir * /admin/login 302
            }
        }
        reverse_proxy https://prometheus:9090 {
            import internal-mtls
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }

    # ── Static assets — public, no auth required (CSS/JS for admin UI) ────
    handle /static/* {
        reverse_proxy https://backoffice:8443 {
        import internal-mtls
        import inject-caddy-verified
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }

    # ── User login page — /login (before catch-all) ────────────────────────
    handle /login {
        reverse_proxy https://backoffice:8443 {
        import internal-mtls
        import inject-caddy-verified
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }

    # ── /app/webui — Open WebUI user path (Phase 2 / 2.25.5-auth-ingress) ────
    # See Caddyfile.selfsigned for full commentary.
    # OWUI is plain HTTP on caddy_internal — no internal-mtls to open-webui:8080.
    handle /app/webui* {
        request_header -X-Forwarded-User
        request_header -X-Forwarded-Name
        request_header -X-Forwarded-Groups
        request_header -X-OpenWebUI-User-Email
        request_header -X-OpenWebUI-User-Id
        request_header -X-OpenWebUI-User-Name
        request_header -X-OpenWebUI-User-Role
        import strip-orchestration-headers

        # ── OWUI socket.io WebSocket (Phase 2 / F-WS fix pattern) ──────────
        @owui_ws {
            header Connection *Upgrade*
            header Upgrade websocket
            path /app/webui/ws/*
        }
        handle @owui_ws {
            forward_auth https://backoffice:8443 {
            import internal-mtls
            import inject-caddy-verified
                uri /auth/verify-user
                copy_headers X-Forwarded-User X-Forwarded-Name X-Forwarded-Email
                header_up -Connection
                header_up -Upgrade

                @unauthorized status 401
                handle_response @unauthorized {
                    respond 401
                }
                @admin_on_user_path status 403
                handle_response @admin_on_user_path {
                    respond 403
                }
            }
            reverse_proxy open-webui:8080 {
                import inject-caddy-verified
                header_up X-Forwarded-Proto https
                header_up X-Real-IP {remote_host}
                header_up X-Forwarded-User {http.request.header.X-Forwarded-User}
                header_up X-Forwarded-Name {http.request.header.X-Forwarded-Name}
                header_up X-Forwarded-Email {http.request.header.X-Forwarded-Email}
            }
        }

        # ── OWUI HTTP (non-WS) ───────────────────────────────────────────────
        handle {
            forward_auth https://backoffice:8443 {
            import internal-mtls
            import inject-caddy-verified
                uri /auth/verify-user
                copy_headers X-Forwarded-User X-Forwarded-Name X-Forwarded-Email

                @unauthorized status 401
                handle_response @unauthorized {
                    redir * /login?next={http.request.uri} 302
                }

                @admin_on_user_path status 403
                handle_response @admin_on_user_path {
                    redir * /admin/ 302
                }
            }

            reverse_proxy open-webui:8080 {
                import inject-caddy-verified
                header_up X-Forwarded-Proto https
                header_up X-Real-IP {remote_host}
                header_up X-Forwarded-User {http.request.header.X-Forwarded-User}
                header_up X-Forwarded-Name {http.request.header.X-Forwarded-Name}
                header_up X-Forwarded-Email {http.request.header.X-Forwarded-Email}
            }
        }
    }

    # ── Prometheus federation — admin-authenticated ─────────────────────────
    # retro #83: Prometheus now serves HTTPS on 9090. Use internal-mtls.
    handle /metrics-federate* {
        basic_auth {
            {env.PROMETHEUS_BASICAUTH_USER} {env.PROMETHEUS_BASICAUTH_HASH}
        }
        # inject-caddy-verified: prometheus does not validate the header but
        # we inject it uniformly across all reverse_proxy blocks. Closes LU-231-10-A.
        reverse_proxy https://prometheus:9090 {
            import internal-mtls
            import inject-caddy-verified
        }
    }

    # ── Root catch-all — portal redirect (Phase 2 / 2.25.5-auth-ingress) ────
    # OWUI has moved off root onto /app/webui.  See Caddyfile.selfsigned.
    handle {
        redir * /login 302
    }
}

http://{$YASHIGANI_TLS_DOMAIN} {
    redir https://{$YASHIGANI_TLS_DOMAIN}{uri} permanent
}

# ─────────────────────────────────────────────────────────────────────────────
# Internal observability listeners — :8444 gateway / :8445 backoffice.
# Mesh-internal only, never published to the host.
# Last updated: 2026-04-24T13:47:12+01:00
#
# Purpose:
#   Prometheus scrapes gateway/backoffice /internal/metrics through Caddy so
#   every scrape goes through our SPIFFE-aware identity gate. mTLS client-cert
#   auth is REQUIRED — Caddy refuses the TLS handshake without one.
#
# Per-port split (#81 fix):
#   Prometheus v3.x rejects setting `Host` via http_headers (forbidden). The
#   previous design used a single :8444 listener with a Host-header matcher
#   to pick gateway vs backoffice — that is incompatible with Prom v3. We
#   now give each upstream its own listener with identical semantics.
#
# Identity forwarding (EX-231-08, zero-trust default):
#   1. `request_header -X-SPIFFE-ID` strips any inbound value. Critical:
#      only Caddy may set this header downstream; an attacker co-located on
#      the internal bridge network who forged it would otherwise bypass the
#      application-layer ACL.
#   2. `request_header X-SPIFFE-ID {http.request.tls.client.san.uris.0}` sets
#      the header from the peer cert's first URI SAN. The peer cert was
#      minted by our internal CA (see yashigani.pki.issuer.build_leaf) with a
#      URI SAN of the form `spiffe://yashigani.internal/<service-name>`.
#   3. The upstream (gateway/backoffice) enforces the allowlist in
#      yashigani.auth.spiffe.require_spiffe_id against the parsed manifest.
#
# These listeners are NOT exposed in docker-compose.yml `ports:` — they are
# only reachable over the internal bridge network.
# ─────────────────────────────────────────────────────────────────────────────
:8444 {
    tls /run/secrets/caddy_client.crt /run/secrets/caddy_client.key {
        client_auth {
            mode require_and_verify
            trust_pool file /run/secrets/ca_intermediate.crt
        }
        protocols tls1.3
        ciphers TLS_AES_256_GCM_SHA384 TLS_AES_128_GCM_SHA256
        curves x25519mlkem768 x25519 secp384r1 secp256r1
    }

    @metrics path /internal/metrics
    handle @metrics {
        # Spoof-prevention: drop any inbound X-SPIFFE-ID before setting our own.
        request_header -X-SPIFFE-ID
        # Populate from the verified peer cert's URI SAN.
        request_header X-SPIFFE-ID {http.request.tls.client.san.uris.0}

        reverse_proxy https://gateway:8080 {
            import internal-mtls
            import inject-caddy-verified
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }

    # Default: reject anything else on this listener.
    handle {
        respond "Not Found" 404
    }
}

# Parallel listener for the backoffice upstream — identical SPIFFE gate,
# identical strip-before-set header discipline.
:8445 {
    tls /run/secrets/caddy_client.crt /run/secrets/caddy_client.key {
        client_auth {
            mode require_and_verify
            trust_pool file /run/secrets/ca_intermediate.crt
        }
        protocols tls1.3
        ciphers TLS_AES_256_GCM_SHA384 TLS_AES_128_GCM_SHA256
        curves x25519mlkem768 x25519 secp384r1 secp256r1
    }

    @metrics path /internal/metrics
    handle @metrics {
        request_header -X-SPIFFE-ID
        request_header X-SPIFFE-ID {http.request.tls.client.san.uris.0}

        reverse_proxy https://backoffice:8443 {
            import internal-mtls
            import inject-caddy-verified
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }

    handle {
        respond "Not Found" 404
    }
}

# ─────────────────────────────────────────────────────────────────────────────
# S4 — Agent import sentinel (P1 W3 Phase 2a)
# Last updated: 2026-05-29T00:00:00+00:00
#
# DESIGN: onboarded-agent Caddyfile snippets are generated by the ringfence-init
# codegen engine (src/yashigani/manifest/codegen.py) and written to
# docker/caddy/agents/<agent>.caddy (compose) or mounted from a per-agent
# ConfigMap projection (K8s). Each snippet is a top-level `:443 { handle_path
# /agents/<tenant>/<agent>/* { ... } }` site block. Caddy merges multiple
# `:443` blocks at parse time — agent routes are appended after the base routes
# defined above, so they never shadow base handles.
#
# IDEMPOTENCY: Caddy `import` with a wildcard glob is idempotent — if the
# directory contains no .caddy files (no agents onboarded yet) Caddy logs a
# warning and continues normally. A .gitkeep file in docker/caddy/agents/
# is NOT imported (non-.caddy extension).
#
# SECURITY: the bind-mount (docker-compose.yml) and ConfigMap (Helm) are both
# read-only. Agent snippets are generated by install.sh/ringfence-init; an
# operator cannot inject arbitrary Caddy config by dropping a file here without
# access to the host filesystem (compose) or K8s RBAC (Helm).
#
# NEVER regenerate the Caddyfile monolith — agent routes live in snippets only.
# ─────────────────────────────────────────────────────────────────────────────
import /etc/caddy/agents/*.caddy
